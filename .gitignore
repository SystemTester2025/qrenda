# Laravel uploads:
# Ignore real uploads directory (generated at runtime)
storage/app/public/
# Keep public symlink target contents ignored (Laravel public/storage)
public/storage

# Laravel 5 & Lumen older public paths (keep for compatibility)
public/hot
public_html/storage
public_html/hot


# Laravel
/bootstrap/cache/*
# Laravel 4 specific
bootstrap/compiled.php

# Ignore compiled views / caches (Laravel default)
storage/*.key
storage/logs/
storage/framework/
storage/framework/cache/
storage/framework/sessions/
